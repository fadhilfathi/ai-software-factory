# =============================================================================
# AI Software Factory — Environment Variables
# =============================================================================
# Copy this to .env and customise:
#   cp .env.example .env
# Then: docker compose up -d --build
#
# Variables are read in two contexts:
#   1. Docker Compose (POSTGRES_*, *_PORT, NEXT_PUBLIC_API_URL, etc.)
#   2. The Go API process (DB_*, JWT_SECRET, CORS_*, RATE_LIMIT_*, AGENT_*)
#
# Anything the API reads but that is NOT documented here will cause the
# service to refuse to start (config.Load() panics on missing required vars).
# =============================================================================

# --- Docker ---
COMPOSE_PROJECT_NAME=ai-software-factory

# --- API Backend ---
# HTTP port the Go API listens on (overridable via PORT as well).
API_PORT=8080
# Allowed values: debug, info, warn, error. Default: info.
LOG_LEVEL=info

# --- Frontend ---
# Port the Next.js dev server / runner listens on inside the container.
FRONTEND_PORT=3000
# Public URL the browser uses to reach the API. Must include the /v1 prefix.
# Use "api" for in-network compose; use "localhost:8080" from the host.
NEXT_PUBLIC_API_URL=http://api:8080/v1

# --- PostgreSQL ---
# These are the env vars the postgres Docker image consumes.
# The Go API process reads the DB_* group below, not POSTGRES_*.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=project
POSTGRES_PORT=5432

# --- API: database connection (REQUIRED for the Go process to start) ---
# config.Load() will panic if any of DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME
# is unset. The compose file wires these to the `db` service.
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=project
# 'disable' is fine for in-network docker; 'require' for managed Postgres.
DB_SSLMODE=disable

# --- API: HTTP server ---
# config.Load() reads SERVER_HOST/SERVER_PORT; main.go also honours PORT
# (which overrides SERVER_PORT). Default 8080 either way.
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# PORT=8080

# --- API: graceful shutdown ---
# Total budget (Go duration string) for the SIGINT/SIGTERM shutdown path.
# The HTTP server gets the full budget to stop accepting and drain
# in-flight requests; the Execution service gets whatever time is left to
# cancel its stop context and drain in-flight mock goroutines. Default 10s.
SHUTDOWN_GRACE=10s

# --- API: authentication ---
# JWT_SECRET is REQUIRED by config.Load(). It must be at least 32 characters
# long (the auth service enforces this and exits otherwise). Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-plus-character-random-secret-string

# --- API: API key auth (F-002, Sprint 4) ---
# Seeds the in-memory APIKeyStore at process start. Format is a
# semicolon-separated list of `<raw_key>,<user_uuid>` entries. The raw
# key is hashed (sha256 of the post-`ak_` part) before being stored;
# the raw key is never persisted.
#
# Example (two keys):
#   API_KEYS_DEV=ak_devkey_001,11111111-1111-1111-1111-111111111111;ak_devkey_002,22222222-2222-2222-2222-222222222222
#
# If unset, a single dev fallback key is loaded (the raw value is
# `ak_dev_local_only_change_in_production_2026_06_12` with user
# 00000000-0000-0000-0000-000000000001). Set to empty string to disable
# API key auth entirely.
# Production: set this to the real keys (or a credential-rotation
# pipeline). The Postgres-backed implementation is deferred to a
# follow-up sprint task.
# API_KEYS_DEV=

# --- API: CORS ---
# Comma-separated list of allowed origins. Empty means "same-origin only".
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Whether to allow credentials (cookies, authorization headers) on CORS.
CORS_ALLOW_CREDENTIALS=true

# --- API: rate limiting ---
RATE_LIMIT_RPM=100
RATE_LIMIT_BURST=20

# --- Redis ---
REDIS_PORT=6379

# --- Agent Sandbox ---
AGENT_RUNTIME=runc
AGENT_MEMORY_MB=512
AGENT_CPU_LIMIT=50000
