# =============================================================================
# AI Software Factory — Environment Variables
# =============================================================================
# Copy this to .env and customise:
#   cp .env.example .env
# Then: docker compose up -d --build
# =============================================================================

# --- API Backend ---
API_PORT=8080
LOG_LEVEL=info

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://api:8080/v1

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=project
POSTGRES_PORT=5432
